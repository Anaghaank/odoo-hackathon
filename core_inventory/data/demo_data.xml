<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- =====================
             PRODUCT CATEGORIES
             ===================== -->
        <record id="cat_raw" model="core.product.category">
            <field name="name">Raw Materials</field>
        </record>
        <record id="cat_elec" model="core.product.category">
            <field name="name">Electronics</field>
        </record>
        <record id="cat_tools" model="core.product.category">
            <field name="name">Tools &amp; Equipment</field>
        </record>
        <record id="cat_pack" model="core.product.category">
            <field name="name">Packaging</field>
        </record>

        <!-- =====================
             WAREHOUSE
             ===================== -->
        <record id="wh_main" model="core.warehouse">
            <field name="name">Main Logistics Hub</field>
            <field name="code">MAIN</field>
        </record>

        <!-- =====================
             LOCATIONS
             ===================== -->
        <record id="loc_input" model="core.location">
            <field name="name">Input Zone</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="usage">supplier</field>
            <field name="barcode">LOC-INPUT</field>
        </record>

        <record id="loc_stock" model="core.location">
            <field name="name">Main Stock</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="usage">internal</field>
            <field name="barcode">LOC-STOCK</field>
            <field name="removal_strategy">fifo</field>
        </record>

        <record id="loc_shelf_a" model="core.location">
            <field name="name">Shelf A</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="parent_id" ref="loc_stock"/>
            <field name="usage">internal</field>
            <field name="barcode">LOC-SHELF-A</field>
        </record>

        <record id="loc_shelf_b" model="core.location">
            <field name="name">Shelf B</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="parent_id" ref="loc_stock"/>
            <field name="usage">internal</field>
            <field name="barcode">LOC-SHELF-B</field>
        </record>

        <record id="loc_dispatch" model="core.location">
            <field name="name">Dispatch Zone</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="usage">customer</field>
            <field name="barcode">LOC-DISPATCH</field>
        </record>

        <record id="loc_scrap" model="core.location">
            <field name="name">Scrap Bin</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="usage">inventory</field>
            <field name="scrap_location" eval="True"/>
        </record>

        <!-- =====================
             PRODUCTS
             ===================== -->
        <record id="prod_steel" model="core.product">
            <field name="name">Steel Rods (12mm)</field>
            <field name="sku">STR-001</field>
            <field name="category_id" ref="cat_raw"/>
            <field name="uom_char">kg</field>
            <field name="low_stock_threshold">50.0</field>
        </record>

        <record id="prod_copper" model="core.product">
            <field name="name">Copper Wire (2.5mm)</field>
            <field name="sku">CPW-002</field>
            <field name="category_id" ref="cat_raw"/>
            <field name="uom_char">meters</field>
            <field name="low_stock_threshold">100.0</field>
        </record>

        <record id="prod_laptop" model="core.product">
            <field name="name">Enterprise Laptop V4</field>
            <field name="sku">LAP-099</field>
            <field name="category_id" ref="cat_elec"/>
            <field name="uom_char">Units</field>
            <field name="low_stock_threshold">5.0</field>
        </record>

        <record id="prod_mouse" model="core.product">
            <field name="name">Wireless Mouse Pro</field>
            <field name="sku">MSE-011</field>
            <field name="category_id" ref="cat_elec"/>
            <field name="uom_char">Units</field>
            <field name="low_stock_threshold">10.0</field>
        </record>

        <record id="prod_drill" model="core.product">
            <field name="name">Electric Power Drill</field>
            <field name="sku">TL-DRL</field>
            <field name="category_id" ref="cat_tools"/>
            <field name="uom_char">Units</field>
            <field name="low_stock_threshold">2.0</field>
        </record>

        <record id="prod_box" model="core.product">
            <field name="name">Cardboard Box (Large)</field>
            <field name="sku">PKG-BOX-L</field>
            <field name="category_id" ref="cat_pack"/>
            <field name="uom_char">Units</field>
            <field name="low_stock_threshold">20.0</field>
        </record>

        <!-- =====================
             REORDERING RULES
             ===================== -->
        <record id="rule_steel" model="core.reordering.rule">
            <field name="product_id" ref="prod_steel"/>
            <field name="location_id" ref="loc_stock"/>
            <field name="min_qty">50.0</field>
            <field name="max_qty">500.0</field>
        </record>

        <record id="rule_laptop" model="core.reordering.rule">
            <field name="product_id" ref="prod_laptop"/>
            <field name="location_id" ref="loc_stock"/>
            <field name="min_qty">5.0</field>
            <field name="max_qty">30.0</field>
        </record>

        <!-- =====================
             STOCK MOVES (Initial Load — populates stock levels for Dashboard &amp; Products)
             ===================== -->
        <record id="move_steel_in" model="core.stock.move">
            <field name="name">DEMO/INIT/001</field>
            <field name="product_id" ref="prod_steel"/>
            <field name="qty">120.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_a"/>
            <field name="state">done</field>
        </record>

        <record id="move_copper_in" model="core.stock.move">
            <field name="name">DEMO/INIT/002</field>
            <field name="product_id" ref="prod_copper"/>
            <field name="qty">350.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_a"/>
            <field name="state">done</field>
        </record>

        <record id="move_laptop_in" model="core.stock.move">
            <field name="name">DEMO/INIT/003</field>
            <field name="product_id" ref="prod_laptop"/>
            <field name="qty">12.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_b"/>
            <field name="state">done</field>
        </record>

        <record id="move_mouse_in" model="core.stock.move">
            <field name="name">DEMO/INIT/004</field>
            <field name="product_id" ref="prod_mouse"/>
            <field name="qty">50.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_b"/>
            <field name="state">done</field>
        </record>

        <record id="move_drill_in" model="core.stock.move">
            <field name="name">DEMO/INIT/005</field>
            <field name="product_id" ref="prod_drill"/>
            <field name="qty">3.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_a"/>
            <field name="state">done</field>
        </record>

        <record id="move_box_in" model="core.stock.move">
            <field name="name">DEMO/INIT/006</field>
            <field name="product_id" ref="prod_box"/>
            <field name="qty">200.0</field>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_shelf_b"/>
            <field name="state">done</field>
        </record>

        <!-- A simulated outgoing move so stock levels look realistic -->
        <record id="move_steel_out" model="core.stock.move">
            <field name="name">DEMO/SHIP/001</field>
            <field name="product_id" ref="prod_steel"/>
            <field name="qty">30.0</field>
            <field name="location_id" ref="loc_shelf_a"/>
            <field name="location_dest_id" ref="loc_dispatch"/>
            <field name="state">done</field>
        </record>

        <record id="move_mouse_out" model="core.stock.move">
            <field name="name">DEMO/SHIP/002</field>
            <field name="product_id" ref="prod_mouse"/>
            <field name="qty">8.0</field>
            <field name="location_id" ref="loc_shelf_b"/>
            <field name="location_dest_id" ref="loc_dispatch"/>
            <field name="state">done</field>
        </record>

        <!-- =====================
             PENDING PICKINGS (so Dashboard shows pending counts)
             ===================== -->
        <record id="pick_receipt_pending" model="core.picking">
            <field name="name">WH/IN/DEMO-01</field>
            <field name="picking_type">receipt</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="location_id" ref="loc_input"/>
            <field name="location_dest_id" ref="loc_stock"/>
            <field name="state">ready</field>
        </record>

        <record id="pick_delivery_pending" model="core.picking">
            <field name="name">WH/OUT/DEMO-01</field>
            <field name="picking_type">delivery</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="location_id" ref="loc_stock"/>
            <field name="location_dest_id" ref="loc_dispatch"/>
            <field name="state">waiting</field>
        </record>

        <record id="pick_internal_pending" model="core.picking">
            <field name="name">WH/INT/DEMO-01</field>
            <field name="picking_type">internal</field>
            <field name="warehouse_id" ref="wh_main"/>
            <field name="location_id" ref="loc_shelf_a"/>
            <field name="location_dest_id" ref="loc_shelf_b"/>
            <field name="state">draft</field>
        </record>

    </data>
</odoo>
