<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Warehouse Views -->
    <record id="view_core_warehouse_tree" model="ir.ui.view">
        <field name="name">core.warehouse.tree</field>
        <field name="model">core.warehouse</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_core_warehouse_form" model="ir.ui.view">
        <field name="name">core.warehouse.form</field>
        <field name="model">core.warehouse</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <notebook>
                        <page string="Locations">
                            <field name="location_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="usage"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_core_warehouse" model="ir.actions.act_window">
        <field name="name">Warehouses</field>
        <field name="res_model">core.warehouse</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_action_core_warehouse" name="Locations / Warehouses" parent="menu_core_warehouse" action="action_core_warehouse" sequence="10"/>

</odoo>
