<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Categories -->
    <record id="view_core_product_category_tree" model="ir.ui.view">
        <field name="name">core.product.category.tree</field>
        <field name="model">core.product.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="view_core_product_category_form" model="ir.ui.view">
        <field name="name">core.product.category.form</field>
        <field name="model">core.product.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_core_product_category" model="ir.actions.act_window">
        <field name="name">Product Categories</field>
        <field name="res_model">core.product.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_core_product_category" name="Categories" parent="menu_core_inventory_products" action="action_core_product_category" sequence="20"/>

    <!-- Products -->
    <record id="view_core_product_tree" model="ir.ui.view">
        <field name="name">core.product.tree</field>
        <field name="model">core.product</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_low_stock">
                <field name="name"/>
                <field name="sku"/>
                <field name="category_id"/>
                <field name="stock_qty" string="Stock"/>
                <field name="uom_char" string="UoM"/>
                <field name="is_low_stock" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Product Kanban -->
    <record id="view_core_product_kanban" model="ir.ui.view">
        <field name="name">core.product.kanban</field>
        <field name="model">core.product</field>
        <field name="arch" type="xml">
            <kanban cards_clickable="1">
                <field name="id"/>
                <field name="name"/>
                <field name="sku"/>
                <field name="uom_char"/>
                <field name="stock_qty"/>
                <field name="is_low_stock"/>
                <field name="category_id"/>
                <templates>
                    <t t-name="card">
                        <!-- Accent top bar -->
                        <div class="ci-kanban-header-bar"/>
                        <div class="d-flex flex-column p-2 gap-2">
                            <!-- Title row -->
                            <div class="d-flex justify-content-between align-items-start">
                                <strong class="o_kanban_record_title" style="font-size:.95rem;font-weight:700;color:#212529;">
                                    <field name="name"/>
                                </strong>
                                <span t-if="record.is_low_stock.raw_value" class="ci-low-stock-badge">Low Stock</span>
                            </div>
                            <!-- SKU + Category -->
                            <div class="d-flex align-items-center gap-2">
                                <span style="font-size:.72rem;background:#f0f4ff;color:#4361ee;border-radius:6px;padding:2px 8px;font-weight:600;">
                                    <field name="sku"/>
                                </span>
                                <span t-if="record.category_id.value" style="font-size:.72rem;color:#6c757d;">
                                    <field name="category_id"/>
                                </span>
                            </div>
                            <!-- Stock quantity -->
                            <div class="d-flex align-items-baseline gap-1 mt-1">
                                <span class="ci-stock-badge"><field name="stock_qty"/></span>
                                <span class="ci-stock-unit"><field name="uom_char"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_core_product_form" model="ir.ui.view">
        <field name="name">core.product.form</field>
        <field name="model">core.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_stock_locations" type="object" class="oe_stat_button" icon="fa-building-o" string="Stock per Location"/>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Product Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Steel Rods"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sku"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="stock_qty"/>
                            <field name="uom_char"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Product Search -->
    <record id="view_core_product_search" model="ir.ui.view">
        <field name="name">core.product.search</field>
        <field name="model">core.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sku"/>
                <field name="category_id"/>
                <filter string="Low Stock" name="filter_low_stock" domain="[('is_low_stock', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_core_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">core.product</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_core_product_search"/>
    </record>

    <menuitem id="menu_core_product" name="Products" parent="menu_core_inventory_products" action="action_core_product" sequence="10"/>

    <!-- Reordering Rules -->
    <record id="view_core_reordering_rule_tree" model="ir.ui.view">
        <field name="name">core.reordering.rule.list</field>
        <field name="model">core.reordering.rule</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="min_qty"/>
                <field name="max_qty"/>
            </list>
        </field>
    </record>

    <record id="action_core_reordering_rule" model="ir.actions.act_window">
        <field name="name">Reordering Rules</field>
        <field name="res_model">core.reordering.rule</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_core_reordering_rule" name="Reordering Rules" parent="menu_core_inventory_products" action="action_core_reordering_rule" sequence="30"/>

</odoo>
