<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Form View -->
    <record id="view_core_dashboard_form" model="ir.ui.view">
        <field name="name">core.dashboard.form</field>
        <field name="model">core.dashboard</field>
        <field name="arch" type="xml">
            <form string="Inventory Dashboard" create="0" delete="0" edit="0">
                <sheet>

                    <!-- ── Page Header ── -->
                    <div class="ci-dashboard-header">
                        <div class="ci-dashboard-header-inner">
                            <span class="ci-header-icon">🏭</span>
                            <div>
                                <h2 class="ci-header-title">CoreInventory Dashboard</h2>
                                <p class="ci-header-subtitle">Real-time snapshot of your warehouse operations</p>
                            </div>
                        </div>
                    </div>

                    <!-- ── KPI Grid ── -->
                    <div class="ci-dashboard-wrapper">

                        <!-- Row 1 | 3 tiles -->
                        <div class="row g-3">

                            <div class="col-12 col-md-4">
                                <div class="ci-kpi-tile ci-tile-blue">
                                    <div class="ci-kpi-icon">📦</div>
                                    <div class="ci-kpi-value"><field name="total_products"/></div>
                                    <div class="ci-kpi-label">Products in Stock</div>
                                    <button name="action_view_all_products" type="object"
                                            class="ci-kpi-link">View Products →</button>
                                </div>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="ci-kpi-tile ci-tile-red">
                                    <div class="ci-kpi-icon">⚠️</div>
                                    <div class="ci-kpi-value"><field name="low_stock_items"/></div>
                                    <div class="ci-kpi-label">Low / Out of Stock</div>
                                    <button name="action_view_low_stock" type="object"
                                            class="ci-kpi-link">View Alerts →</button>
                                </div>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="ci-kpi-tile ci-tile-green">
                                    <div class="ci-kpi-icon">📥</div>
                                    <div class="ci-kpi-value"><field name="pending_receipts"/></div>
                                    <div class="ci-kpi-label">Pending Receipts</div>
                                    <button name="action_view_receipts" type="object"
                                            class="ci-kpi-link">View Receipts →</button>
                                </div>
                            </div>

                        </div>

                        <!-- Row 2 | 2 tiles -->
                        <div class="row g-3 mt-3">

                            <div class="col-12 col-md-6">
                                <div class="ci-kpi-tile ci-tile-amber">
                                    <div class="ci-kpi-icon">📤</div>
                                    <div class="ci-kpi-value"><field name="pending_deliveries"/></div>
                                    <div class="ci-kpi-label">Pending Deliveries</div>
                                    <button name="action_view_deliveries" type="object"
                                            class="ci-kpi-link">View Deliveries →</button>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="ci-kpi-tile ci-tile-teal">
                                    <div class="ci-kpi-icon">🔄</div>
                                    <div class="ci-kpi-value"><field name="internal_transfers"/></div>
                                    <div class="ci-kpi-label">Internal Transfers</div>
                                    <button name="action_view_transfers" type="object"
                                            class="ci-kpi-link">View Transfers →</button>
                                </div>
                            </div>

                        </div>

                    </div><!-- /.ci-dashboard-wrapper -->

                </sheet>
            </form>
        </field>
    </record>

</odoo>
